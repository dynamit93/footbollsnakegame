# Required for production builds (e.g. Vercel). Must be your NODE API host, NOT the Vercel UI URL.
# Wrong:  https://my-game.vercel.app
# Right: https://my-game-api.onrender.com
VITE_SERVER_URL=

# Optional: Socket.IO API URL when running `vite dev` (default http://localhost:3001)
# VITE_DEV_SERVER_URL=http://localhost:3001
